# ─────────────────────────────────────────────────────────────────────────────
# TransitOps — Environment Configuration Example
# Copy this file to .env and fill in real values before running the app.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Project ─────────────────────────────────────────────────────────────────
PROJECT_NAME=TransitOps API

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5435
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=transitops

# Optional: set full DATABASE_URL to override the above components.
# Must use postgresql+asyncpg:// driver scheme for async SQLAlchemy.
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5435/transitops

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# REQUIRED: Replace with a secure random secret in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=supersecretkeychangeinproduction1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
