# Project Settings
PROJECT_NAME="TransitOps API"
API_V1_STR="/api"

# CORS Configuration (comma-separated origins)
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000", "http://127.0.0.1:5173"]'

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_PORT=5435
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=transitops

# Database URL override (optional, defaults to postgresql+asyncpg://user:pass@server:port/db)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5435/transitops

# Security / JWT Configuration
# SECRET_KEY should be a long random string in production (e.g. generate via: openssl rand -hex 32)
SECRET_KEY=supersecretkeychangeinproduction1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
